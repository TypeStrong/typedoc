{
    "compilerOptions": {
        "types": ["node"],
        "target": "ESNext",
        "module": "CommonJS",
        "jsx": "react",
        "experimentalDecorators": true,
        "resolveJsonModule": true,
        "rootDir": ".",
        "strictNullChecks": true,
        "allowJs": true,
        "noEmit": true,
        "outDir": "dist",

        "strictPropertyInitialization": false,
        "noImplicitAny": false
    },
    "include": ["."]
}
